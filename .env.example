# Required
# --------

# Notion Integration Token
# Create at: https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API Key
# Create at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Bot Token
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram Chat ID
# Send /start to your bot, then visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=123456789

# Optional — Research Packs
# -------------------------

# Finnhub (financial pack — earnings, company news)
# https://finnhub.io/
# FINNHUB_API_KEY=xxx

# CoinGecko (financial pack — crypto prices)
# https://www.coingecko.com/en/api
# COINGECKO_API_KEY=xxx

# Jooble (jobs pack — job search API)
# https://jooble.org/api/about
# JOOBLE_API_KEY=xxx

# RapidAPI (jobs pack — JSearch)
# https://rapidapi.com/
# RAPIDAPI_KEY=xxx

# Optional — Google Calendar
# ---------------------------
# Path to credentials JSON file
# GOOGLE_CREDENTIALS=path/to/credentials.json
